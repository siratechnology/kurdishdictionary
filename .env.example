# Copy this file to .env and fill in the values
SQL_SA_PASSWORD=YourStrong@Passw0rd
SQL_USER_PASSWORD=YourAppUserPassword

# JWT signing key for the admin dashboard login.
# MUST be set: the backend refuses to start in Production without it, because a shipped default key
# would let anyone forge an admin token. Rotating it signs every user out.
# Generate one with:  openssl rand -base64 48
JWT_KEY=ChangeMeToA64CharRandomStringGeneratedWithOpensslRandBase64

# Seeded accounts, created on first run only. Change these passwords after logging in.
SEED_ADMIN_USER=sirwan
SEED_ADMIN_EMAIL=sirwanjaff999@gmail.com
SEED_ADMIN_PASSWORD=Admin@123!
SEED_EDITOR_PASSWORD=Editor@123!

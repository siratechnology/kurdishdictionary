@* A ranked list with proportional bars — countries, cities, browsers, devices all share this shape. *@

<div class="rounded-2xl border border-gray-100 bg-white p-5 shadow-sm">
    <h2 class="mb-4 text-sm font-bold text-gray-900">@Title</h2>

    @if (Items.Count == 0)
    {
        <p class="py-6 text-center text-xs text-gray-400">هێشتا داتا نییە</p>
    }
    else
    {
        var max = Items.Max(i => i.Count);

        <div class="space-y-2.5">
            @foreach (var item in Items.Take(Take))
            {
                <div>
                    <div class="mb-1 flex items-baseline justify-between gap-2">
                        <span class="min-w-0 truncate text-xs text-gray-700" title="@item.Name">@item.Name</span>
                        <span class="shrink-0 text-xs font-semibold text-gray-500">@item.Count</span>
                    </div>
                    <div class="h-1.5 overflow-hidden rounded-full bg-gray-100">
                        <div class="h-full rounded-full bg-indigo-500"
                             style="width: @(max <= 0 ? 0 : (int)(item.Count / (double)max * 100))%"></div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = "";

    // Fully qualified with global::. This component's own namespace is frontend_blazor.Components.Shared,
    // so a bare "Shared.Dtos.NameCountDto" binds "Shared" to the enclosing namespace and looks for a
    // non-existent frontend_blazor.Components.Shared.Dtos. A clean build (e.g. the Docker image) fails
    // on it even though an incremental local build with stale generated files does not.
    [Parameter, EditorRequired] public List<global::Shared.Dtos.NameCountDto> Items { get; set; } = new();
    [Parameter] public int Take { get; set; } = 6;
}

@inject WordService WordSvc

@if (IsVisible)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
        <!-- Backdrop -->
        <div class="absolute inset-0 bg-black/50" @onclick="OnClose"></div>

        <!-- Modal -->
        <div class="relative bg-white dark:bg-gray-800 rounded-2xl shadow-2xl w-full max-w-2xl max-h-[90vh] flex flex-col">

            <!-- Header -->
            <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 dark:border-gray-700">
                <div>
                    <h2 class="text-lg font-bold text-gray-900 dark:text-white">
                        @(EditingWord is null ? "زیادکردنی وشەی نوێ" : "دەستکاریکردنی وشە")
                    </h2>
                    @if (EditingWord is not null)
                    {
                        <p class="text-xs text-gray-400 mt-0.5" dir="rtl">@EditingWord.Kurdish</p>
                    }
                </div>
                <button @onclick="OnClose" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 w-8 h-8 flex items-center justify-center rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors text-lg leading-none">✕</button>
            </div>

            <!-- Body -->
            <div class="overflow-y-auto flex-1 px-6 py-5 space-y-5">

                <!-- Kurdish Word -->
                <div>
                    <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">
                        وشەی کوردی <span class="text-red-500">*</span>
                    </label>
                    <input @bind="Kurdish" @bind:event="oninput"
                           dir="rtl"
                           placeholder="وشەکە بنووسە..."
                           class="w-full border @(string.IsNullOrWhiteSpace(Kurdish) && _submitted ? "border-red-400 ring-1 ring-red-400" : "border-gray-300 dark:border-gray-600") rounded-xl px-4 py-2.5 text-base bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-colors" />
                    @if (string.IsNullOrWhiteSpace(Kurdish) && _submitted)
                    {
                        <p class="text-red-500 text-xs mt-1 flex items-center gap-1">
                            <span>⚠</span> وشەی کوردی پێویستە.
                        </p>
                    }
                </div>

                <!-- Speech Type + Category -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">
                            جۆری وشە (Part of Speech)
                        </label>
                        @if (_speechTypes.Any())
                        {
                            <select @bind="SpeechPane"
                                    class="w-full border border-gray-300 dark:border-gray-600 rounded-xl px-4 py-2.5 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-colors">
                                @foreach (var st in _speechTypes)
                                {
                                    <option value="@st.Id">@st.Kurdish</option>
                                }
                            </select>
                        }
                        else
                        {
                            <div class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm text-gray-400 bg-gray-50">بارکردن...</div>
                        }
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">
                            بەش / Category
                        </label>
                        <input @bind="Category" @bind:event="oninput"
                               list="wf-category-list"
                               placeholder="بەشێک هەڵبژێرە یان بنووسە..."
                               class="w-full border border-gray-300 dark:border-gray-600 rounded-xl px-4 py-2.5 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-colors" />
                        <datalist id="wf-category-list">
                            @foreach (var c in Categories)
                            {
                                <option value="@c" />
                            }
                        </datalist>
                    </div>
                </div>

                <!-- Description -->
                <div>
                    <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5">تێبینی / Description</label>
                    <textarea @bind="Description" @bind:event="oninput"
                              rows="2"
                              placeholder="تێبینی زیادە..."
                              class="w-full border border-gray-300 dark:border-gray-600 rounded-xl px-4 py-2.5 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-none transition-colors"></textarea>
                </div>

                <!-- ── WordMeans section ─────────────────────────────────────── -->
                <div class="rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                    <!-- Section header -->
                    <div class="flex items-center justify-between px-4 py-3 bg-gray-50 dark:bg-gray-700/50 border-b border-gray-200 dark:border-gray-700">
                        <div class="flex items-center gap-2">
                            <span class="text-base">📝</span>
                            <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">مانا و وەرگێڕانەکان</span>
                        </div>
                        @if (Meanings.Any())
                        {
                            <span class="text-xs font-medium text-indigo-600 bg-indigo-50 dark:bg-indigo-900/30 px-2 py-0.5 rounded-full">
                                @Meanings.Count
                            </span>
                        }
                    </div>

                    <div class="p-4 space-y-3">
                        <!-- Existing meanings -->
                        @if (Meanings.Any())
                        {
                            <div class="space-y-2">
                                @for (int i = 0; i < Meanings.Count; i++)
                                {
                                    var idx = i;
                                    var m = Meanings[idx];
                                    <div class="flex items-start gap-3 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-600 rounded-xl px-3 py-2.5 group">
                                        <div class="flex-1 min-w-0">
                                            <p class="text-sm font-medium text-gray-800 dark:text-gray-200 leading-snug" dir="rtl">@m.Meaning</p>
                                            @if (!string.IsNullOrEmpty(m.Locate))
                                            {
                                                <span class="inline-block mt-1 text-xs text-gray-400 bg-gray-100 dark:bg-gray-700 px-2 py-0.5 rounded-full">@m.Locate</span>
                                            }
                                        </div>
                                        <button @onclick="() => RemoveMeaning(idx)"
                                                class="shrink-0 mt-0.5 opacity-0 group-hover:opacity-100 text-red-400 hover:text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 w-6 h-6 flex items-center justify-center rounded-lg transition-all text-sm">
                                            ✕
                                        </button>
                                    </div>
                                }
                            </div>
                        }

                        <!-- Add new meaning form -->
                        <div class="border border-dashed border-gray-300 dark:border-gray-600 rounded-xl p-3 space-y-2.5 bg-gray-50/50 dark:bg-gray-700/20">
                            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">+ زیادکردنی مانای نوێ</p>

                            <textarea @bind="_newMeaning" @bind:event="oninput"
                                      dir="rtl" rows="2"
                                      placeholder="مانا یان وەرگێڕان بنووسە..."
                                      class="w-full border border-gray-300 dark:border-gray-600 rounded-xl px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-none transition-colors"></textarea>

                            <div class="flex gap-2 items-center">
                                <!-- Locate combobox -->
                                <div class="flex-1 relative">
                                    <input @bind="_newLocate" @bind:event="oninput"
                                           list="wf-locate-list"
                                           placeholder="زمان / Locate  (بۆ نموونە: English)"
                                           class="w-full border border-gray-300 dark:border-gray-600 rounded-xl px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-colors" />
                                    <datalist id="wf-locate-list">
                                        @foreach (var loc in LocateOptions)
                                        {
                                            <option value="@loc" />
                                        }
                                    </datalist>
                                </div>
                                <button @onclick="AddMeaning"
                                        disabled="@(string.IsNullOrWhiteSpace(_newMeaning))"
                                        class="shrink-0 inline-flex items-center gap-1 bg-indigo-600 hover:bg-indigo-700 disabled:opacity-40 text-white text-xs font-semibold px-3 py-2 rounded-xl transition-colors">
                                    + زیاد
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Footer -->
            <div class="px-6 py-4 border-t border-gray-100 dark:border-gray-700 flex justify-end gap-3">
                <button @onclick="OnClose"
                        class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 rounded-xl hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">
                    پاشگەزبوونەوە
                </button>
                <button @onclick="HandleSave" disabled="@_saving"
                        class="px-6 py-2 text-sm font-semibold text-white bg-indigo-600 rounded-xl hover:bg-indigo-700 disabled:opacity-50 flex items-center gap-2 transition-colors shadow-sm">
                    @if (_saving)
                    {
                        <span class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></span>
                        <span>پاشکەوتکردن...</span>
                    }
                    else
                    {
                        <span>✓ پاشکەوتکردن</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public WordDto? EditingWord { get; set; }
    [Parameter] public List<string> Categories { get; set; } = new();
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    // ── Form fields ───────────────────────────────────────────────────────────
    string Kurdish = "";
    string Category = "";
    string Description = "";
    int SpeechPane = 14; // Other
    List<WordMeansDto> Meanings = new();

    // ── New meaning inputs ───────────────────────────────────────────────────
    string _newMeaning = "";
    string _newLocate = "";

    // ── State ────────────────────────────────────────────────────────────────
    bool _saving;
    bool _submitted;
    List<SpeechTypeItem> _speechTypes = new();

    // ── Locate options: static base + DB values + current word's locates ─────
    static readonly string[] _baseLocates =
    {
        "English", "Arabic", "Persian", "Turkish",
        "Kurdish Badini", "Kurdish Sorani", "Zazaki", "Gorani"
    };

    List<string> _dbLocates = new();

    IEnumerable<string> LocateOptions =>
        _baseLocates
            .Concat(_dbLocates)
            .Concat(Meanings.Select(m => m.Locate ?? "").Where(l => l.Length > 0))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(l => l);

    // ─────────────────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var speechTask = WordSvc.GetSpeechTypesAsync();
        var locateTask = WordSvc.GetLocatesAsync();
        await Task.WhenAll(speechTask, locateTask);
        _speechTypes = await speechTask;
        _dbLocates   = await locateTask;
    }

    protected override void OnParametersSet()
    {
        if (!IsVisible) return;

        if (EditingWord is not null)
        {
            Kurdish = EditingWord.Kurdish;
            Category = EditingWord.Category ?? "";
            Description = EditingWord.Description ?? "";
            SpeechPane = EditingWord.SpeechPane > 0 ? EditingWord.SpeechPane : 14;
            Meanings = EditingWord.Meanings.Select(m => new WordMeansDto
            {
                Id = m.Id,
                Meaning = m.Meaning,
                Locate = m.Locate
            }).ToList();
        }
        else
        {
            Kurdish = Category = Description = "";
            SpeechPane = 14;
            Meanings = new();
        }
        _submitted = false;
        _newMeaning = "";
        _newLocate = "";
    }

    // ── WordMeans helpers ─────────────────────────────────────────────────────
    void AddMeaning()
    {
        if (string.IsNullOrWhiteSpace(_newMeaning)) return;
        Meanings.Add(new WordMeansDto
        {
            Meaning = _newMeaning.Trim(),
            Locate = string.IsNullOrWhiteSpace(_newLocate) ? null : _newLocate.Trim()
        });
        _newMeaning = "";
        _newLocate = "";
    }

    void RemoveMeaning(int index)
    {
        if (index >= 0 && index < Meanings.Count)
            Meanings.RemoveAt(index);
    }

    // ── Save ─────────────────────────────────────────────────────────────────
    async Task HandleSave()
    {
        _submitted = true;
        if (string.IsNullOrWhiteSpace(Kurdish)) return;
        _saving = true;

        var meanings = Meanings.Select(m => new WordMeansDto
        {
            Meaning = m.Meaning,
            Locate = m.Locate
        }).ToList();

        if (EditingWord is null)
        {
            await WordSvc.CreateWordAsync(new CreateWordDto
            {
                Kurdish = Kurdish.Trim(),
                SpeechPane = SpeechPane,
                Category = NullIfEmpty(Category),
                Description = NullIfEmpty(Description),
                Meanings = meanings,
                RelatedWords = new()
            });
        }
        else
        {
            // Preserve existing relations when saving from this form
            var relations = EditingWord.OutgoingRelations.Select(r => new CreateRelatedWordDto
            {
                TargetWordId = r.RelatedWordId,
                RelationType = r.RelationType,
                Weight = r.Weight
            }).ToList();

            await WordSvc.UpdateWordAsync(EditingWord.Id, new UpdateWordDto
            {
                Kurdish = Kurdish.Trim(),
                SpeechPane = SpeechPane,
                Category = NullIfEmpty(Category),
                Description = NullIfEmpty(Description),
                Meanings = meanings,
                RelatedWords = relations
            });
        }

        _saving = false;
        await OnSaved.InvokeAsync();
    }

    static string? NullIfEmpty(string s) =>
        string.IsNullOrWhiteSpace(s) ? null : s.Trim();
}

@* Seeded accounts ship with a password that is written down in the repo. Nag until it is replaced. *@

<AuthorizeView>
    @if (context.User.FindFirst("mustChangePassword")?.Value == "True")
    {
        <div class="mb-6 flex flex-wrap items-center gap-3 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3">
            <span class="text-lg">🔐</span>
            <p class="flex-1 text-sm text-amber-900">
                <span class="font-semibold">وشەی نهێنیت بگۆڕە.</span>
                ئەم هەژمارە هێشتا وشەی نهێنی سەرەتایی بەکاردەهێنێت.
            </p>
            <a href="/profile"
               class="rounded-lg bg-amber-600 px-3 py-1.5 text-xs font-semibold text-white transition hover:bg-amber-700">
                گۆڕینی وشەی نهێنی
            </a>
        </div>
    }
</AuthorizeView>

@page "/denied"
@layout EmptyLayout
@attribute [AllowAnonymous]

<PageTitle>ڕێگەپێنەدراو</PageTitle>

<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
    <div class="text-center max-w-sm">
        <div class="inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-amber-100 text-3xl mb-5">
            🔒
        </div>
        <h1 class="text-xl font-bold text-gray-900 mb-2">ڕێگەت پێنەدراوە</h1>
        <p class="text-sm text-gray-500 mb-6">
            ڕۆڵی هەژمارەکەت ڕێگەی پێنادات ئەم بەشە ببینێت. ئەگەر پێویستت پێیەتی، پەیوەندی بە بەڕێوەبەرەوە بکە.
        </p>
        <a href="/" class="inline-block rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-700 transition">
            گەڕانەوە بۆ داشبۆرد
        </a>
    </div>
</div>

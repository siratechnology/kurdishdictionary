@page "/relations"
@rendermode InteractiveServer
@inject WordService WordSvc

<PageTitle>بەڕێوەبردنی پەیوەندییەکان</PageTitle>

<!-- Page header -->
<div class="flex items-center justify-between mb-6" dir="rtl">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">پەیوەندییەکان</h1>
        <p class="text-sm text-gray-400 mt-0.5">
            @_listWords.Count(w => w.TotalRelations == 0) وشە بەبێ پەیوەندی ·
            @_listWords.Count(w => w.TotalRelations > 0) وشە بە پەیوەندی
        </p>
    </div>
    <div class="flex items-center gap-2">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-amber-50 border border-amber-200 text-xs font-semibold text-amber-700">
            <span class="w-2 h-2 rounded-full bg-amber-400"></span>
            بەبێ پەیوەندی
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-emerald-50 border border-emerald-200 text-xs font-semibold text-emerald-700">
            <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
            بە پەیوەندی
        </span>
    </div>
</div>

<!-- Two-column layout -->
<div class="flex gap-5" style="height: calc(100vh - 180px); min-height: 500px;">

    <!-- ══════════════════════════════════════════════════════════════
         LEFT PANEL — word list
    ══════════════════════════════════════════════════════════════ -->
    <div class="w-72 shrink-0 flex flex-col gap-3 overflow-hidden">

        <!-- Search box -->
        <div dir="rtl">
            <input value="@_listSearch" @oninput="OnListSearch"
                   placeholder="🔍 گەڕان لە وشەکان..."
                   dir="rtl"
                   class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm bg-white shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 transition-all" />
        </div>

        <!-- Word list (scrollable) -->
        <div class="flex-1 overflow-y-auto bg-white rounded-2xl border border-gray-200 shadow-sm">
            @if (_listLoading)
            {
                @for (int i = 0; i < 10; i++)
                {
                    <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-50 animate-pulse" dir="rtl">
                        <div class="flex-1 h-4 bg-gray-200 rounded-lg"></div>
                        <div class="w-6 h-5 bg-gray-100 rounded-full"></div>
                    </div>
                }
            }
            else if (!_listWords.Any())
            {
                <div class="flex flex-col items-center justify-center py-12 text-gray-400 gap-2">
                    <span class="text-3xl">📭</span>
                    <p class="text-sm">هیچ وشەیەک نەدۆزرایەوە</p>
                </div>
            }
            else
            {
                @foreach (var w in _listWords)
                {
                    bool isSelected = _selectedWord?.Id == w.Id;
                    <button @onclick="() => SelectWord(w)"
                            class="w-full flex items-center gap-3 px-4 py-3 border-b border-gray-50 last:border-0 text-right transition-colors @(isSelected ? "bg-indigo-50 border-r-2 border-indigo-500" : "hover:bg-gray-50")"
                            dir="rtl">
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-bold text-gray-900 truncate">@w.Kurdish</p>
                            @if (!string.IsNullOrEmpty(w.Category))
                            {
                                <p class="text-[10px] text-gray-400 truncate mt-0.5">@w.Category</p>
                            }
                        </div>
                        @if (w.TotalRelations == 0)
                        {
                            <span class="shrink-0 text-[10px] font-bold px-1.5 py-0.5 rounded-full bg-amber-100 text-amber-600 border border-amber-200">٠</span>
                        }
                        else
                        {
                            <span class="shrink-0 text-[10px] font-bold px-1.5 py-0.5 rounded-full bg-emerald-100 text-emerald-700 border border-emerald-200">@w.TotalRelations</span>
                        }
                    </button>
                }

                @if (_listHasMore)
                {
                    <button @onclick="LoadMoreWords"
                            disabled="@_listLoadingMore"
                            class="w-full py-3 text-xs font-semibold text-indigo-600 hover:bg-indigo-50 transition-colors border-t border-gray-100 disabled:opacity-40">
                        @(_listLoadingMore ? "بارکردن..." : "+ وشەی زیاتر")
                    </button>
                }
            }
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════════
         RIGHT PANEL — relation manager
    ══════════════════════════════════════════════════════════════ -->
    <div class="flex-1 flex flex-col gap-4 overflow-hidden min-w-0">

        @if (_selectedWord is null)
        {
            <div class="flex-1 flex flex-col items-center justify-center text-center text-gray-400 bg-white rounded-2xl border border-gray-200 border-dashed gap-4 p-8">
                <div class="w-16 h-16 rounded-2xl bg-indigo-50 border border-indigo-100 flex items-center justify-center text-3xl">🕸</div>
                <div>
                    <p class="font-semibold text-gray-600 text-base">وشەیەک هەڵبژێرە</p>
                    <p class="text-sm text-gray-400 mt-1.5 leading-relaxed">
                        لە لیستی لای چەپەوە وشەیەک هەڵبژێرە<br/>بۆ بینینی پەیوەندییەکان و زیادکردنی پەیوەندی نوێ
                    </p>
                </div>
            </div>
        }
        else
        {
            <!-- Selected word header -->
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm px-5 py-4" dir="rtl">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-3 flex-wrap">
                        <span class="text-2xl font-black text-gray-900">@_selectedWord.Kurdish</span>
                        @if (!string.IsNullOrEmpty(_selectedWord.SpeechPaneKurdish))
                        {
                            <span class="text-xs font-semibold px-2.5 py-1 bg-violet-100 text-violet-700 rounded-full">@_selectedWord.SpeechPaneKurdish</span>
                        }
                        @if (!string.IsNullOrEmpty(_selectedWord.Category))
                        {
                            <span class="text-xs font-medium px-2.5 py-1 bg-indigo-50 text-indigo-600 rounded-full border border-indigo-100">@_selectedWord.Category</span>
                        }
                    </div>
                    <div class="shrink-0 flex items-center gap-3">
                        <span class="text-xs font-semibold px-3 py-1.5 bg-gray-100 text-gray-600 rounded-xl">
                            @(_selectedWord.OutgoingRelations.Count + _selectedWord.IncomingRelations.Count) پەیوەندی
                        </span>
                    </div>
                </div>
            </div>

            <div class="flex-1 flex flex-col gap-4 overflow-y-auto pb-1 pr-0.5">

                <!-- ── Current relations ── -->
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden" dir="rtl">
                    <div class="flex items-center justify-between px-5 py-3.5 bg-gray-50 border-b border-gray-100">
                        <span class="text-sm font-bold text-gray-800">پەیوەندییە ئێستاکان</span>
                        @if (!_selectedWord.OutgoingRelations.Any() && !_selectedWord.IncomingRelations.Any())
                        {
                            <span class="text-xs font-medium text-amber-600 bg-amber-50 px-2.5 py-1 rounded-full border border-amber-200">
                                هیچ پەیوەندییەک نییە
                            </span>
                        }
                        else
                        {
                            <span class="text-xs font-semibold text-gray-400">
                                @_selectedWord.OutgoingRelations.Count خروج · @_selectedWord.IncomingRelations.Count دەرچوو
                            </span>
                        }
                    </div>

                    @{
                        var grouped  = _selectedWord.OutgoingRelations.GroupBy(r => r.RelationType).OrderBy(g => g.Key).ToList();
                        var incoming = _selectedWord.IncomingRelations.ToList();
                    }

                    @if (!grouped.Any() && !incoming.Any())
                    {
                        <div class="px-5 py-8 text-center">
                            <p class="text-sm text-gray-400">هێشتا هیچ پەیوەندییەک زیادنەکراوە</p>
                            <p class="text-xs text-gray-300 mt-1">لە خوارەوە پەیوەندی زیاد بکە</p>
                        </div>
                    }
                    else
                    {
                        <div class="p-5 space-y-4">

                            @foreach (var group in grouped)
                            {
                                <div>
                                    <div class="flex items-center gap-2 mb-2">
                                        <span class="text-[10px] font-bold uppercase tracking-wider text-gray-400">@RelLabel(group.Key)</span>
                                        <span class="text-[10px] font-bold text-gray-300">(@group.Count())</span>
                                    </div>
                                    <div class="flex flex-wrap gap-2">
                                        @foreach (var rel in group)
                                        {
                                            <span class="inline-flex items-center gap-1.5 pl-1.5 pr-3 py-1.5 rounded-full text-sm font-semibold @RelChipClass(group.Key)">
                                                <button @onclick="() => DeleteRelation(rel)"
                                                        disabled="@_saving"
                                                        class="w-4 h-4 flex items-center justify-center rounded-full hover:bg-black/10 text-xs leading-none disabled:opacity-40 transition-colors shrink-0">
                                                    ×
                                                </button>
                                                @rel.RelatedKurdish
                                            </span>
                                        }
                                    </div>
                                </div>
                            }

                            @if (incoming.Any())
                            {
                                <div class="pt-3 border-t border-gray-100">
                                    <div class="flex items-center gap-2 mb-2">
                                        <span class="text-[10px] font-bold uppercase tracking-wider text-gray-400">ئاماژەی بۆ کراوە</span>
                                        <span class="text-[10px] font-bold text-gray-300">(@incoming.Count)</span>
                                    </div>
                                    <div class="flex flex-wrap gap-2">
                                        @foreach (var rel in incoming)
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-semibold bg-gray-100 text-gray-500 border border-gray-200"
                                                  title="@rel.RelationType">
                                                ← @rel.RelatedKurdish
                                            </span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- ── Add new relations ── -->
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden" dir="rtl">
                    <div class="px-5 py-3.5 bg-gray-50 border-b border-gray-100">
                        <span class="text-sm font-bold text-gray-800">+ زیادکردنی پەیوەندی نوێ</span>
                    </div>

                    <div class="p-5 space-y-4">

                        <!-- Multi-select combobox -->
                        <div>
                            <label class="block text-xs font-semibold text-gray-500 mb-2 uppercase tracking-wide">وشەکانی مەبەست</label>

                            <div class="min-h-[44px] border-2 @(_comboFocused ? "border-indigo-400 ring-2 ring-indigo-100" : "border-gray-200") rounded-xl px-3 py-2 flex flex-wrap gap-1.5 items-center cursor-text transition-all bg-white"
                                 @onclick="FocusComboInput">

                                @foreach (var pick in _picks)
                                {
                                    <span class="inline-flex items-center gap-1 pl-1.5 pr-2.5 py-1 bg-indigo-100 text-indigo-700 rounded-full text-sm font-semibold">
                                        <button @onclick:stopPropagation="true"
                                                @onclick="() => RemovePick(pick)"
                                                class="w-4 h-4 flex items-center justify-center rounded-full hover:bg-indigo-200 text-xs leading-none">
                                            ×
                                        </button>
                                        @pick.Kurdish
                                    </span>
                                }

                                <input @ref="_comboInputRef"
                                       value="@_comboSearch"
                                       @oninput="OnComboInput"
                                       @onfocus="() => _comboFocused = true"
                                       @onblur="OnComboBlur"
                                       placeholder="@(_picks.Any() ? "" : "وشە بگەڕێ و هەڵبژێرە...")"
                                       dir="rtl"
                                       class="flex-1 min-w-[140px] outline-none text-sm bg-transparent placeholder-gray-400 py-0.5" />
                            </div>

                            @if (_comboSuggestions.Any())
                            {
                                <div class="relative">
                                    <ul class="absolute top-1 left-0 right-0 bg-white border border-gray-200 rounded-xl shadow-xl max-h-48 overflow-y-auto z-40">
                                        @foreach (var s in _comboSuggestions)
                                        {
                                            bool isPicked = _picks.Any(p => p.Id == s.Id);
                                            <li @onclick="() => TogglePick(s)"
                                                class="flex items-center justify-between px-4 py-2.5 text-sm cursor-pointer border-b border-gray-50 last:border-0 @(isPicked ? "bg-indigo-50" : "hover:bg-gray-50") transition-colors">
                                                <span class="font-bold text-gray-800" dir="rtl">@s.Kurdish</span>
                                                <div class="flex items-center gap-2 shrink-0">
                                                    @if (!string.IsNullOrEmpty(s.SpeechPaneKurdish))
                                                    {
                                                        <span class="text-[10px] text-gray-400">@s.SpeechPaneKurdish</span>
                                                    }
                                                    @if (isPicked)
                                                    {
                                                        <span class="w-4 h-4 flex items-center justify-center bg-indigo-500 text-white rounded-full text-[9px] font-bold">✓</span>
                                                    }
                                                </div>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            }
                        </div>

                        <!-- Relation type selector -->
                        <div>
                            <label class="block text-xs font-semibold text-gray-500 mb-2 uppercase tracking-wide">جۆری پەیوەندی</label>
                            <div class="flex flex-wrap gap-2">
                                @foreach (var rt in _relTypes)
                                {
                                    <button @onclick="() => _addRelType = rt.Key"
                                            class="px-3 py-1.5 rounded-xl text-xs font-semibold border-2 transition-all @(_addRelType == rt.Key ? rt.ActiveClass : rt.IdleClass)">
                                        @rt.Label
                                    </button>
                                }
                            </div>
                        </div>

                        <!-- Feedback messages -->
                        @if (!string.IsNullOrEmpty(_saveError))
                        {
                            <div class="flex items-center gap-2 px-3 py-2.5 bg-red-50 border border-red-200 rounded-xl text-xs font-medium text-red-600">
                                <span>⚠</span> @_saveError
                            </div>
                        }
                        @if (_saveSuccess)
                        {
                            <div class="flex items-center gap-2 px-3 py-2.5 bg-emerald-50 border border-emerald-200 rounded-xl text-xs font-medium text-emerald-700">
                                <span>✓</span> پەیوەندییەکان بەسەرکەوتوویی زیاد کران
                            </div>
                        }

                        <!-- Add button -->
                        <button @onclick="AddRelations"
                                disabled="@(!CanAdd || _saving)"
                                class="w-full flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-700 disabled:opacity-40 disabled:cursor-not-allowed text-white font-semibold px-5 py-2.5 rounded-xl shadow-sm transition-colors text-sm">
                            @if (_saving)
                            {
                                <span class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
                                <span>پاشەکەوتکردن...</span>
                            }
                            else
                            {
                                <span>+ زیادکردنی @_picks.Count پەیوەندی</span>
                            }
                        </button>
                    </div>
                </div>

            </div>
        }
    </div>
</div>

@code {
    // ── Word list (left panel) ──────────────────────────────────────────────
    List<WordDto> _listWords = new();
    string _listSearch = "";
    bool _listLoading = true;
    bool _listLoadingMore;
    bool _listHasMore;
    int _listPage = 1;
    const int ListPageSize = 30;
    CancellationTokenSource? _listCts;

    // ── Selected word ───────────────────────────────────────────────────────
    WordDto? _selectedWord;
    bool _saving;
    bool _saveSuccess;
    string _saveError = "";

    // ── Multi-select combobox ───────────────────────────────────────────────
    string _comboSearch = "";
    List<WordDto> _comboSuggestions = new();
    List<WordDto> _picks = new();
    bool _comboFocused;
    ElementReference _comboInputRef;
    CancellationTokenSource? _comboCts;

    string _addRelType = "synonym";

    bool CanAdd => _picks.Any() && !string.IsNullOrEmpty(_addRelType) && _selectedWord is not null;

    // ── Relation type config ────────────────────────────────────────────────
    record RelTypeConfig(string Key, string Label, string ActiveClass, string IdleClass);

    readonly List<RelTypeConfig> _relTypes = new()
    {
        new("synonym",    "هاوماناکە",       "border-emerald-500 bg-emerald-50 text-emerald-700",  "border-gray-200 text-gray-500 hover:border-emerald-300 hover:text-emerald-600"),
        new("antonym",    "دژەوشە",          "border-red-500     bg-red-50     text-red-700",      "border-gray-200 text-gray-500 hover:border-red-300     hover:text-red-600"),
        new("related",    "پەیوەندیدار",     "border-blue-500    bg-blue-50    text-blue-700",     "border-gray-200 text-gray-500 hover:border-blue-300    hover:text-blue-600"),
        new("example",    "نموونە",          "border-amber-500   bg-amber-50   text-amber-700",    "border-gray-200 text-gray-500 hover:border-amber-300   hover:text-amber-600"),
        new("usage",      "بکارهێنان",       "border-purple-500  bg-purple-50  text-purple-700",   "border-gray-200 text-gray-500 hover:border-purple-300  hover:text-purple-600"),
        new("contextual", "چارچێوەیی",       "border-cyan-500    bg-cyan-50    text-cyan-700",     "border-gray-200 text-gray-500 hover:border-cyan-300    hover:text-cyan-600"),
        new("partof",     "بەشێکە لە وشەکە", "border-orange-500  bg-orange-50  text-orange-700",   "border-gray-200 text-gray-500 hover:border-orange-300  hover:text-orange-600"),
    };

    // ═══════════════════════════════════════════════════════════════════════
    protected override async Task OnInitializedAsync()
    {
        await LoadListPage(reset: true);
    }

    async Task LoadListPage(bool reset)
    {
        if (reset) { _listPage = 1; _listWords = new(); _listLoading = true; }
        else _listLoadingMore = true;

        var result  = await WordSvc.GetWordsAsync(_listPage, ListPageSize, _listSearch);
        var incoming = result?.Items ?? new();

        if (reset) _listWords = incoming;
        else _listWords.AddRange(incoming);

        _listHasMore    = incoming.Count == ListPageSize;
        _listLoading    = false;
        _listLoadingMore = false;
    }

    async Task LoadMoreWords() { _listPage++; await LoadListPage(reset: false); }

    async Task OnListSearch(ChangeEventArgs e)
    {
        _listSearch = e.Value?.ToString() ?? "";
        _listCts?.Cancel();
        _listCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(300, _listCts.Token);
            await LoadListPage(reset: true);
        }
        catch (TaskCanceledException) { }
    }

    // ═══════════════════════════════════════════════════════════════════════
    async Task SelectWord(WordDto w)
    {
        _saveSuccess = false;
        _saveError   = "";
        ResetCombo();
        var full     = await WordSvc.GetWordByIdAsync(w.Id);
        _selectedWord = full ?? w;
    }

    // ═══════════════════════════════════════════════════════════════════════
    async Task OnComboInput(ChangeEventArgs e)
    {
        _comboSearch = e.Value?.ToString() ?? "";
        _comboCts?.Cancel();
        _comboCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(250, _comboCts.Token);
            if (string.IsNullOrWhiteSpace(_comboSearch)) { _comboSuggestions = new(); return; }
            var result = await WordSvc.GetWordsAsync(search: _comboSearch, pageSize: 10);
            _comboSuggestions = (result?.Items ?? new())
                .Where(w => w.Id != _selectedWord?.Id && !_picks.Any(p => p.Id == w.Id))
                .ToList();
        }
        catch (TaskCanceledException) { }
    }

    void TogglePick(WordDto w)
    {
        var existing = _picks.FirstOrDefault(p => p.Id == w.Id);
        if (existing is not null) _picks.Remove(existing);
        else _picks.Add(w);
        _comboSuggestions = _comboSuggestions.ToList();
        _saveSuccess = false;
        _saveError   = "";
    }

    void RemovePick(WordDto w) => _picks.Remove(w);

    async Task FocusComboInput() => await _comboInputRef.FocusAsync();

    async Task OnComboBlur()
    {
        await Task.Delay(200);
        _comboFocused = false;
        if (string.IsNullOrWhiteSpace(_comboSearch)) _comboSuggestions = new();
    }

    void ResetCombo()
    {
        _picks           = new();
        _comboSearch     = "";
        _comboSuggestions = new();
        _comboFocused    = false;
    }

    // ═══════════════════════════════════════════════════════════════════════
    async Task AddRelations()
    {
        if (!CanAdd || _selectedWord is null) return;
        _saving = true; _saveError = ""; _saveSuccess = false;
        try
        {
            var existing = _selectedWord.OutgoingRelations
                .Select(r => new CreateRelatedWordDto { TargetWordId = r.RelatedWordId, RelationType = r.RelationType, Weight = r.Weight })
                .ToList();

            var toAdd = _picks
                .Where(p => !existing.Any(e => e.TargetWordId == p.Id && e.RelationType == _addRelType))
                .Select(p => new CreateRelatedWordDto { TargetWordId = p.Id, RelationType = _addRelType, Weight = 1 })
                .ToList();

            if (!toAdd.Any()) { _saveError = "هەموو وشەکانی هەڵبژێردراو پێشتر زیاد کراون."; return; }

            existing.AddRange(toAdd);

            var dto = new UpdateWordDto
            {
                Kurdish      = _selectedWord.Kurdish,
                SpeechPane   = _selectedWord.SpeechPane,
                Category     = _selectedWord.Category,
                Description  = _selectedWord.Description,
                Meanings     = _selectedWord.Meanings.Select(m => new WordMeansDto { Meaning = m.Meaning, Locate = m.Locate }).ToList(),
                RelatedWords = existing
            };

            var updated = await WordSvc.UpdateWordAsync(_selectedWord.Id, dto);
            if (updated is not null)
            {
                _selectedWord = updated;
                _saveSuccess  = true;
                ResetCombo();
                RefreshWordInList(updated);
            }
            else _saveError = "کێشەیەک ڕووی دا. دووبارە هەوڵ بدەرەوە.";
        }
        catch { _saveError = "پەیوەستی نێوخۆ بپشکنە."; }
        finally { _saving = false; }
    }

    // ═══════════════════════════════════════════════════════════════════════
    async Task DeleteRelation(RelatedWordDto rel)
    {
        if (_selectedWord is null) return;
        _saving = true; _saveError = ""; _saveSuccess = false;
        try
        {
            var remaining = _selectedWord.OutgoingRelations
                .Where(r => r.Id != rel.Id)
                .Select(r => new CreateRelatedWordDto { TargetWordId = r.RelatedWordId, RelationType = r.RelationType, Weight = r.Weight })
                .ToList();

            var dto = new UpdateWordDto
            {
                Kurdish      = _selectedWord.Kurdish,
                SpeechPane   = _selectedWord.SpeechPane,
                Category     = _selectedWord.Category,
                Description  = _selectedWord.Description,
                Meanings     = _selectedWord.Meanings.Select(m => new WordMeansDto { Meaning = m.Meaning, Locate = m.Locate }).ToList(),
                RelatedWords = remaining
            };

            var updated = await WordSvc.UpdateWordAsync(_selectedWord.Id, dto);
            if (updated is not null) { _selectedWord = updated; RefreshWordInList(updated); }
            else _saveError = "سڕینەوە سەرکەوتوو نەبوو.";
        }
        catch { _saveError = "سڕینەوە سەرکەوتوو نەبوو."; }
        finally { _saving = false; }
    }

    // ═══════════════════════════════════════════════════════════════════════
    void RefreshWordInList(WordDto updated)
    {
        var idx = _listWords.FindIndex(w => w.Id == updated.Id);
        if (idx >= 0)
        {
            updated.TotalRelations = updated.OutgoingRelations.Count + updated.IncomingRelations.Count;
            _listWords[idx] = updated;
        }
    }

    string RelLabel(string type) => type switch
    {
        "synonym"    => "هاوماناکە",
        "antonym"    => "دژەوشە",
        "related"    => "پەیوەندیدار",
        "example"    => "نموونە",
        "usage"      => "بکارهێنان",
        "contextual" => "چارچێوەیی",
        "partof"     => "بەشێکە لە وشەکە",
        _            => type
    };

    string RelChipClass(string type) => type switch
    {
        "synonym"    => "bg-emerald-100 text-emerald-700",
        "antonym"    => "bg-red-100 text-red-700",
        "related"    => "bg-blue-100 text-blue-700",
        "example"    => "bg-amber-100 text-amber-700",
        "usage"      => "bg-purple-100 text-purple-700",
        "contextual" => "bg-cyan-100 text-cyan-700",
        "partof"     => "bg-orange-100 text-orange-700",
        _            => "bg-gray-100 text-gray-600"
    };

@page "/"
@rendermode InteractiveServer
@inject WordService WordSvc

<PageTitle>فەرھەنگی کوردی</PageTitle>

<!-- Top bar -->
<div class="flex items-center justify-between gap-4 mb-6" dir="rtl">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">وشەکان</h1>
        <p class="text-sm text-gray-400">@_totalCount وشە تۆمارکراوە</p>
    </div>
    <button @onclick="OpenAdd"
            class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium px-5 py-2.5 rounded-xl shadow-sm transition-colors text-sm">
        + وشەی نوێ
    </button>
</div>

<!-- Search + Filter row -->
<div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-3 mb-5 flex flex-col sm:flex-row gap-2" dir="rtl">
    <input value="@_search" @oninput="OnSearchInput"
           placeholder="🔍  گەڕان بە ناوی کوردی..."
           dir="rtl"
           class="flex-1 border border-gray-200 rounded-xl px-4 py-2.5 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-400" />
    <select @bind="_selectedCategory" @bind:after="LoadWords"
            class="border border-gray-200 rounded-xl px-4 py-2.5 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-400 min-w-[160px]">
        <option value="">هەموو بەشەکان</option>
        @foreach (var cat in _categories)
        {
            <option value="@cat">@cat</option>
        }
    </select>
</div>

<!-- Category pills -->
@if (_categories.Any())
{
    <div class="flex flex-wrap gap-2 mb-5" dir="rtl">
        <button @onclick='() => SetCategory("")'
                class="px-3 py-1 rounded-full text-xs font-medium transition-colors @(_selectedCategory == "" ? "bg-indigo-600 text-white shadow-sm" : "bg-white border border-gray-200 text-gray-600 hover:border-indigo-300 hover:text-indigo-600")">
            هەموو
        </button>
        @foreach (var cat in _categories)
        {
            <button @onclick="() => SetCategory(cat)"
                    class="px-3 py-1 rounded-full text-xs font-medium transition-colors @(_selectedCategory == cat ? "bg-indigo-600 text-white shadow-sm" : "bg-white border border-gray-200 text-gray-600 hover:border-indigo-300 hover:text-indigo-600")">
                @cat
            </button>
        }
    </div>
}

<!-- Loading -->
@if (_loading)
{
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        @for (int i = 0; i < 8; i++)
        {
            <div class="flex items-center gap-4 px-5 py-4 border-b border-gray-50 last:border-0 animate-pulse" dir="rtl">
                <div class="flex-1 space-y-2">
                    <div class="h-5 bg-gray-200 rounded-lg w-32"></div>
                    <div class="h-3.5 bg-gray-100 rounded w-56"></div>
                </div>
                <div class="h-5 bg-gray-100 rounded-full w-14"></div>
            </div>
        }
    </div>
}
else if (!_words.Any())
{
    <div class="text-center py-20 text-gray-400 bg-white rounded-2xl border border-gray-200">
        <p class="text-5xl mb-4">📖</p>
        <p class="text-lg font-medium">هیچ وشەیەک نەدۆزرایەوە</p>
        <p class="text-sm mt-1">وشەی نوێ زیاد بکە</p>
    </div>
}
else
{
    <!-- Word list -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden mb-6">
        @foreach (var (word, idx) in _words.Select((w, i) => (w, i)))
        {
            <div class="group flex items-start gap-4 px-5 py-4 @(idx < _words.Count - 1 ? "border-b border-gray-50" : "") hover:bg-indigo-50/40 transition-colors" dir="rtl">

                <!-- Right: word + badges -->
                <div class="flex-1 min-w-0 space-y-2">
                    <!-- Row 1: word name + speech + category -->
                    <div class="flex flex-wrap items-center gap-2">
                        <span class="text-xl font-bold text-gray-900 leading-tight">@word.Kurdish</span>
                        @if (!string.IsNullOrEmpty(word.SpeechPaneKurdish))
                        {
                            <span class="text-[11px] font-semibold px-2 py-0.5 bg-violet-100 text-violet-700 rounded-full">@word.SpeechPaneKurdish</span>
                        }
                        @if (!string.IsNullOrEmpty(word.Category))
                        {
                            <span class="text-[11px] font-medium px-2 py-0.5 bg-indigo-50 text-indigo-600 rounded-full border border-indigo-100">@word.Category</span>
                        }
                    </div>

                    <!-- Row 2: meanings list -->
                    @if (word.Meanings.Any())
                    {
                        <div class="flex flex-wrap gap-1.5">
                            @foreach (var m in word.Meanings.Take(4))
                            {
                                <span class="inline-flex items-baseline gap-1 text-xs text-gray-600 bg-gray-50 border border-gray-100 px-2.5 py-1 rounded-lg leading-snug">
                                    @if (!string.IsNullOrEmpty(m.Locate))
                                    {
                                        <span class="text-[10px] font-semibold text-indigo-400 shrink-0">@m.Locate</span>
                                        <span class="text-gray-300 text-[10px]">·</span>
                                    }
                                    <span dir="rtl">@m.Meaning</span>
                                </span>
                            }
                            @if (word.Meanings.Count > 4)
                            {
                                <span class="text-xs px-2 py-1 bg-gray-100 text-gray-400 rounded-lg">+@(word.Meanings.Count - 4)</span>
                            }
                        </div>
                    }

                    <!-- Row 3: description (condensed) -->
                    @if (!string.IsNullOrEmpty(word.Description))
                    {
                        <p class="text-xs text-gray-400 leading-relaxed line-clamp-1">@word.Description</p>
                    }

                    <!-- Row 4: relation chips (compact) -->
                    @{
                        var allRelated = word.OutgoingRelations.Concat(word.IncomingRelations).ToList();
                    }
                    @if (allRelated.Any())
                    {
                        <div class="flex flex-wrap gap-1">
                            @foreach (var rw in allRelated.Take(6))
                            {
                                <span class="text-[11px] px-2 py-0.5 rounded-full font-medium @RelationColor(rw.RelationType)"
                                      title="@((rw.IsIncoming ? "← " : "→ ") + rw.RelationType)">
                                    @rw.RelatedKurdish
                                </span>
                            }
                            @if (allRelated.Count > 6)
                            {
                                <span class="text-[11px] px-2 py-0.5 bg-gray-100 text-gray-400 rounded-full">+@(allRelated.Count - 6)</span>
                            }
                        </div>
                    }
                </div>

                <!-- Left: action buttons (reveal on hover) -->
                <div class="shrink-0 flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity pt-0.5">
                    <button @onclick="() => OpenEdit(word)"
                            class="p-2 text-indigo-500 hover:bg-indigo-100 rounded-lg transition-colors text-sm"
                            title="دەستکاری">
                        ✏
                    </button>
                    <button @onclick="() => ConfirmDelete(word)"
                            class="p-2 text-red-400 hover:bg-red-50 rounded-lg transition-colors text-sm"
                            title="سڕینەوە">
                        🗑
                    </button>
                </div>

            </div>
        }
    </div>

    <!-- Pagination -->
    @if (_totalPages > 1)
    {
        <div class="flex justify-center items-center gap-2" dir="ltr">
            <button @onclick="PrevPage" disabled="@(_currentPage == 1)"
                    class="px-4 py-2 text-sm rounded-xl border border-gray-200 bg-white disabled:opacity-40 hover:bg-gray-50 transition-colors">
                ← پێشتر
            </button>
            <span class="text-sm text-gray-500 px-2">@_currentPage / @_totalPages</span>
            <button @onclick="NextPage" disabled="@(_currentPage == _totalPages)"
                    class="px-4 py-2 text-sm rounded-xl border border-gray-200 bg-white disabled:opacity-40 hover:bg-gray-50 transition-colors">
                دواتر →
            </button>
        </div>
    }
}

<!-- Add/Edit Modal -->
<WordFormModal IsVisible="_showModal"
               EditingWord="_editingWord"
               Categories="_categories"
               OnClose="CloseModal"
               OnSaved="OnSaved" />

<!-- Delete confirmation -->
@if (_deletingWord is not null)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-black/50" @onclick="CancelDelete"></div>
        <div class="relative bg-white rounded-2xl shadow-2xl p-6 w-full max-w-sm text-center" dir="rtl">
            <p class="text-4xl mb-3">🗑</p>
            <h3 class="text-lg font-bold text-gray-900 mb-1">دڵنیای؟</h3>
            <p class="text-gray-500 text-sm mb-5">
                وشەی <strong>"@_deletingWord.Kurdish"</strong> دەسڕێتەوە و ناتوانرێت بگەڕێندرێتەوە.
            </p>
            <div class="flex gap-3">
                <button @onclick="CancelDelete"
                        class="flex-1 px-4 py-2 text-sm font-medium bg-gray-100 text-gray-700 rounded-xl hover:bg-gray-200">
                    پاشگەز
                </button>
                <button @onclick="ExecuteDelete" disabled="@_deleting"
                        class="flex-1 px-4 py-2 text-sm font-medium bg-red-600 text-white rounded-xl hover:bg-red-700 disabled:opacity-50">
                    @(_deleting ? "..." : "سڕینەوە")
                </button>
            </div>
        </div>
    </div>
}

@code {
    List<WordDto> _words = new();
    List<string> _categories = new();
    int _totalCount;
    int _totalPages;
    int _currentPage = 1;
    const int PageSize = 20;

    string _search = "";
    string _selectedCategory = "";
    bool _loading = true;

    bool _showModal;
    WordDto? _editingWord;
    WordDto? _deletingWord;
    bool _deleting;
    CancellationTokenSource? _searchCts;

    protected override async Task OnInitializedAsync() =>
        await Task.WhenAll(LoadWords(), LoadCategories());

    async Task LoadWords()
    {
        _loading = true;
        var result = await WordSvc.GetWordsAsync(_currentPage, PageSize, _search, _selectedCategory);
        _words = result?.Items ?? new();
        _totalCount = result?.TotalCount ?? 0;
        _totalPages = result?.TotalPages ?? 1;
        _loading = false;
    }

    async Task LoadCategories() =>
        _categories = await WordSvc.GetCategoriesAsync();

    async Task OnSearchInput(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? "";
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(350, _searchCts.Token);
            _currentPage = 1;
            await LoadWords();
        }
        catch (TaskCanceledException) { }
    }

    async Task SetCategory(string cat)
    {
        _selectedCategory = cat;
        _currentPage = 1;
        await LoadWords();
    }

    async Task PrevPage() { if (_currentPage > 1) { _currentPage--; await LoadWords(); } }
    async Task NextPage() { if (_currentPage < _totalPages) { _currentPage++; await LoadWords(); } }

    void OpenAdd() { _editingWord = null; _showModal = true; }
    void OpenEdit(WordDto w) { _editingWord = w; _showModal = true; }
    void CloseModal() => _showModal = false;

    async Task OnSaved()
    {
        _showModal = false;
        _currentPage = 1;
        await Task.WhenAll(LoadWords(), LoadCategories());
    }

    void ConfirmDelete(WordDto w) => _deletingWord = w;
    void CancelDelete() => _deletingWord = null;

    async Task ExecuteDelete()
    {
        if (_deletingWord is null) return;
        _deleting = true;
        await WordSvc.DeleteWordAsync(_deletingWord.Id);
        _deletingWord = null;
        _deleting = false;
        await Task.WhenAll(LoadWords(), LoadCategories());
    }

    string RelationColor(string type) => type switch
    {
        "synonym"    => "bg-green-100 text-green-700",
        "antonym"    => "bg-red-100 text-red-700",
        "example"    => "bg-blue-100 text-blue-700",
        "usage"      => "bg-purple-100 text-purple-700",
        "contextual" => "bg-cyan-100 text-cyan-700",
        "partof"     => "bg-orange-100 text-orange-700",
        _            => "bg-gray-100 text-gray-500"
    };
}

@page "/activity"
@page "/audit"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize]
@* Injected as ActivitySvc, not Activity: a member may not share its name with the enclosing class. *@
@inject ActivityService ActivitySvc
@inject NavigationManager Nav

<PageTitle>چالاکییەکان — فەرھەنگی کوردی</PageTitle>

<div class="mb-6 flex flex-wrap items-end justify-between gap-4">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">چالاکییەکان</h1>
        <p class="mt-0.5 text-sm text-gray-400">
            هەموو زیادکردن، دەستکاری و سڕینەوەیەک — لەگەڵ ئەوەی کێ کردوویەتی، لە چ IPیەک و کەی
        </p>
    </div>
    <button @onclick="() => LoadAsync(1)"
            class="shrink-0 rounded-xl bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-700">
        ↻ نوێکردنەوە
    </button>
</div>

@* ── Filters ─────────────────────────────────────────────────────────── *@
<div class="mb-5 flex flex-wrap gap-2">
    @foreach (var filter in ActionFilters)
    {
        <button @onclick="() => SetActionAsync(filter.Value)"
                class="rounded-lg px-3 py-1.5 text-xs font-semibold transition
                       @(_action == filter.Value
                         ? "bg-indigo-600 text-white"
                         : "bg-white text-gray-600 border border-gray-200 hover:bg-gray-50")">
            @filter.Label
        </button>
    }

    <div class="mr-auto">
        <input @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKeyAsync"
               placeholder="گەڕان بە وشە، بەکارهێنەر یان IP..."
               class="w-64 rounded-lg border border-gray-200 px-3 py-1.5 text-xs outline-none transition focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100" />
    </div>
</div>

@if (_loading)
{
    <div class="space-y-2">
        @for (var i = 0; i < 8; i++)
        {
            <div class="skeleton h-16 w-full"></div>
        }
    </div>
}
else if (_logs is null || _logs.Items.Count == 0)
{
    <div class="rounded-2xl border border-gray-100 bg-white py-16 text-center">
        <p class="text-4xl">📭</p>
        <p class="mt-3 text-sm text-gray-400">هیچ چالاکییەک نەدۆزرایەوە</p>
    </div>
}
else
{
    <div class="overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm">
        @* Cards on mobile, table on desktop — a 7-column table is unreadable on a phone. *@
        <div class="divide-y divide-gray-100">
            @foreach (var log in _logs.Items)
            {
                <div class="flex gap-3 p-4 transition hover:bg-gray-50">
                    <span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-sm @ActionStyle(log.Action)">
                        @ActionIcon(log.Action)
                    </span>

                    <div class="min-w-0 flex-1">
                        <div class="flex flex-wrap items-baseline gap-x-1.5 gap-y-0.5">
                            <span class="text-sm font-semibold text-gray-900">@(log.UserName ?? "نەناسراو")</span>
                            <span class="text-sm text-gray-600">@ActionText(log.Action)</span>
                            <span class="text-sm font-medium text-indigo-700">@(log.Summary ?? EntityLabel(log.EntityType))</span>
                            <span class="rounded bg-gray-100 px-1.5 py-0.5 text-[10px] font-medium text-gray-500">
                                @EntityLabel(log.EntityType)@(log.EntityId > 0 ? $" #{log.EntityId}" : "")
                            </span>
                        </div>

                        @* Field-level diff — the "what exactly changed" that a plain log line can't show. *@
                        @{
                            var changes = ActivityService.ParseChanges(log.Changes);
                        }
                        @if (changes.Count > 0)
                        {
                            <div class="mt-2 space-y-1 rounded-lg bg-gray-50 p-2.5">
                                @foreach (var change in changes)
                                {
                                    <div class="flex flex-wrap items-center gap-1.5 text-xs">
                                        <span class="font-semibold text-gray-500">@FieldLabel(change.Field):</span>
                                        <span class="rounded bg-red-50 px-1.5 py-0.5 text-red-700 line-through decoration-red-300">
                                            @Display(change.Old)
                                        </span>
                                        <span class="text-gray-300">←</span>
                                        <span class="rounded bg-emerald-50 px-1.5 py-0.5 text-emerald-700">
                                            @Display(change.New)
                                        </span>
                                    </div>
                                }
                            </div>
                        }

                        <div class="mt-1.5 flex flex-wrap items-center gap-x-3 gap-y-1 text-[11px] text-gray-400">
                            <span title="@log.CreatedAt.ToString("u")">🕐 @Ago(log.CreatedAt)</span>

                            @if (!string.IsNullOrEmpty(log.IpAddress))
                            {
                                <a href="@($"https://ipinfo.io/{log.IpAddress}")" target="_blank" rel="noopener"
                                   class="font-mono text-indigo-500 hover:underline">🌐 @log.IpAddress</a>
                            }

                            @if (!string.IsNullOrEmpty(log.City) || !string.IsNullOrEmpty(log.Country))
                            {
                                <span>📍 @string.Join(", ", new[] { log.City, log.Country }.Where(x => !string.IsNullOrEmpty(x)))</span>
                            }

                            @if (!string.IsNullOrEmpty(log.UserAgent))
                            {
                                <span class="max-w-xs truncate" title="@log.UserAgent">💻 @log.UserAgent</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    @* ── Paging ───────────────────────────────────────────────────────── *@
    <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
        <p class="text-xs text-gray-400">
            @_logs.TotalCount تۆمار — لاپەڕەی @_page لە @TotalPages
        </p>
        <div class="flex gap-2">
            <button @onclick="() => LoadAsync(_page - 1)" disabled="@(_page <= 1)"
                    class="rounded-lg border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-gray-600 transition hover:bg-gray-50 disabled:cursor-not-allowed disabled:opacity-40">
                پێشوو
            </button>
            <button @onclick="() => LoadAsync(_page + 1)" disabled="@(_page >= TotalPages)"
                    class="rounded-lg border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-gray-600 transition hover:bg-gray-50 disabled:cursor-not-allowed disabled:opacity-40">
                دواتر
            </button>
        </div>
    </div>
}

@code {
    private const int PageSize = 30;

    private static readonly (string Label, string? Value)[] ActionFilters =
    {
        ("هەمووی", null),
        ("زیادکراو", "Create"),
        ("دەستکاریکراو", "Update"),
        ("سڕدراوە", "Delete"),
        ("چوونەژوورەوە", "Login"),
        ("هەوڵی سەرنەکەوتوو", "LoginFailed"),
    };

    private PagedResultDto<AuditLogDto>? _logs;
    private bool _loading = true;
    private int _page = 1;
    private string? _action;
    private string _search = "";

    private int TotalPages => _logs is null || _logs.TotalCount == 0
        ? 1
        : (int)Math.Ceiling(_logs.TotalCount / (double)PageSize);

    protected override async Task OnInitializedAsync() => await LoadAsync(1);

    private async Task SetActionAsync(string? action)
    {
        _action = action;
        await LoadAsync(1);
    }

    private async Task OnSearchKeyAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoadAsync(1);
    }

    private async Task LoadAsync(int page)
    {
        if (page < 1) return;

        _loading = true;
        _page = page;
        StateHasChanged();

        try
        {
            _logs = await ActivitySvc.GetAsync(page, PageSize, _action, search: _search);
        }
        catch (ApiUnauthorizedException)
        {
            Nav.NavigateTo("/login", forceLoad: true);
            return;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string Display(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "—" : value.Length > 60 ? value[..60] + "…" : value;

    private static string FieldLabel(string field) => field switch
    {
        "Kurdish" => "وشە",
        "Description" => "وەسف",
        "Gender" => "ڕەگەز",
        "Name" => "ناو",
        "Meaning" => "واتا",
        "Locate" => "شوێن",
        "RelationType" => "جۆری پەیوەندی",
        "Weight" => "کێش",
        _ => field,
    };

    private static string ActionIcon(string action) => action switch
    {
        "Create" => "＋",
        "Update" => "✎",
        "Delete" => "🗑",
        "Login" => "→",
        "LoginFailed" => "⚠",
        _ => "•",
    };

    private static string ActionStyle(string action) => action switch
    {
        "Create" => "bg-emerald-100 text-emerald-700",
        "Update" => "bg-amber-100 text-amber-700",
        "Delete" => "bg-red-100 text-red-700",
        "LoginFailed" => "bg-red-100 text-red-700",
        "Login" => "bg-blue-100 text-blue-700",
        _ => "bg-gray-100 text-gray-600",
    };

    private static string ActionText(string action) => action switch
    {
        "Create" => "زیادیکرد",
        "Update" => "دەستکاریی کرد",
        "Delete" => "سڕییەوە",
        "Login" => "چووە ژوورەوە",
        "LoginFailed" => "هەوڵی سەرنەکەوتووی چوونەژوورەوە",
        "CreateUser" => "بەکارهێنەری زیادکرد",
        "UpdateUser" => "بەکارهێنەری دەستکاری کرد",
        "DeleteUser" => "بەکارهێنەری سڕییەوە",
        _ => action,
    };

    private static string EntityLabel(string entityType) => entityType switch
    {
        "Word" => "وشە",
        "Category" => "پۆل",
        "WordMeans" => "واتا",
        "RelatedWord" => "پەیوەندی",
        "WordCategory" => "پۆلێنکردن",
        "WordSpeechPane" => "جۆری وشە",
        "User" => "بەکارهێنەر",
        _ => entityType,
    };

    private static string Ago(DateTime utc)
    {
        var span = DateTime.UtcNow - utc;

        if (span.TotalSeconds < 60) return "ئێستا";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes} خولەک لەمەوپێش";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours} کاتژمێر لەمەوپێش";
        if (span.TotalDays < 30) return $"{(int)span.TotalDays} ڕۆژ لەمەوپێش";
        return utc.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
    }
}
